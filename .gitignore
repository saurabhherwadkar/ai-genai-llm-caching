# -------------------------------------------------------------------
# .gitignore
# Patterns for files and directories to exclude from version control.
# -------------------------------------------------------------------

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
.env

# Distribution and build artifacts
dist/
build/
*.egg-info/
*.egg

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini

# Dependency directories
node_modules/

# Test and coverage output
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Log files
logs/
*.log

# Database files
data/
*.db
*.sqlite3

# Environment and secrets
.env
.env.local
.env.production
*.pem
*.key
*.crt

# Sentence-transformers model cache
.cache/

# Jupyter notebook checkpoints
.ipynb_checkpoints/
