# -------------------------------------------------------------------
# .env.example
# Example environment variables for the LLM Caching application.
# Copy this file to .env and fill in the actual values.
# -------------------------------------------------------------------

# OpenAI API Key (required for production use)
LLM_CACHE_LLM__API_KEY=your-openai-api-key-here

# Override LLM provider (openai or mock)
LLM_CACHE_LLM__PROVIDER=mock

# Override log level (DEBUG, INFO, WARN, ERROR)
LLM_CACHE_LOGGING__LEVEL=INFO

# Override cache backend (memory or sqlite)
LLM_CACHE_CACHE__BACKEND=sqlite

# Override similarity thresholds
LLM_CACHE_SIMILARITY__SYNTACTIC_THRESHOLD=0.85
LLM_CACHE_SIMILARITY__SEMANTIC_THRESHOLD=0.80
